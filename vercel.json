{
  "rewrites": [
    { "source": "/panel", "destination": "/panel/index.html" },
    { "source": "/alumna/:slug", "destination": "/alumna/index.html" },
    { "source": "/registro", "destination": "/registro/index.html" },
    { "source": "/ficha/:slug", "destination": "/ficha/index.html" },
    { "source": "/ficha", "destination": "/ficha/index.html" },
    { "source": "/api/sb.js", "destination": "/api/sb.js" },
    { "source": "/sb.js", "destination": "/sb.js" },
    { "source": "/api/seed.json", "destination": "/api/seed.json" },
    { "source": "/sw.js", "destination": "/sw.js" }
  ],
  "headers": [
    { "source": "/sw.js", "headers": [
      { "key": "Service-Worker-Allowed", "value": "/" },
      { "key": "Cache-Control", "value": "no-cache" }
    ]},
    { "source": "/(sb|api/sb).js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }]}
  ]
}