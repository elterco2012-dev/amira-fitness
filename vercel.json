{
  "rewrites": [
    { "source": "/panel", "destination": "/panel/index.html" },
    { "source": "/alumna/:slug", "destination": "/alumna/index.html" },
    { "source": "/alumna", "destination": "/alumna/index.html" },
    { "source": "/registro", "destination": "/registro/index.html" },
    { "source": "/ficha/:slug", "destination": "/ficha/index.html" },
    { "source": "/ficha", "destination": "/ficha/index.html" },
    { "source": "/sb.js", "destination": "/sb.js" },
    { "source": "/api/seed.json", "destination": "/api/seed.json" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/.well-known/assetlinks.json", "destination": "/.well-known/assetlinks.json" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/sb.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/api/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
